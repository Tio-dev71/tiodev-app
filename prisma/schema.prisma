generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  description      String
  price            Float
  image            String
  images           String[]    @default([])
  downloadLink     String?
  category         String?
  featured         Boolean     @default(false)
  active           Boolean     @default(true)
  isSubscription   Boolean     @default(false)
  subscriptionType String?
  embedCode        String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  orderItems       OrderItem[]

  @@index([slug])
  @@index([category])
  @@index([featured])
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique @default(cuid())
  customerName     String
  customerEmail    String
  customerPhone    String?
  shippingAddress  String?
  subtotal         Float
  discount         Float       @default(0)
  total            Float
  status           OrderStatus @default(PENDING)
  paymentMethod    String
  paymentId        String?
  affiliateCode    String?
  syncedToSheets   Boolean     @default(false)
  notes            String?
  tradingViewUser  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  items            OrderItem[]
  affiliate        Affiliate?  @relation(fields: [affiliateCode], references: [code])

  @@index([status])
  @@index([customerEmail])
  @@index([affiliateCode])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Affiliate {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  email           String
  discountPercent Float    @default(10)
  commissionRate  Float    @default(5)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]

  @@index([code])
  @@index([email])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  category    String
  readTime    String
  image       String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  label     String?
  updatedAt DateTime @updatedAt
}
